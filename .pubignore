# Files excluded from the pub.dev package.
# Dotfiles (.dart_tool, .git, .idea, .github, .DS_Store) are excluded by pub.
# Explicitly ignore build outputs so local `flutter test` / `flutter build`
# artifacts never inflate the published tarball.
build/
**/build/

# Screenshots used in the README (binary blobs, not needed by consumers).
doc/

# IntelliJ project file.
progress_card.iml

# Dev helper script for launching the example app locally.
run_example.command

# Internal AI/project notes — not relevant to package consumers.
CLAUDE.md
